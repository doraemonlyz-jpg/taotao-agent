# Pick ONE provider — fill the matching key.
# The default model used by the agent is controlled by AGENT_MODEL.

# --- Anthropic (default) ---
ANTHROPIC_API_KEY=sk-ant-...
AGENT_MODEL=anthropic:claude-sonnet-4-5-20250929
AGENT_FAST_MODEL=anthropic:claude-haiku-4-5

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# AGENT_MODEL=openai:gpt-4o
# AGENT_FAST_MODEL=openai:gpt-4o-mini

# --- Google Gemini ---
# GOOGLE_API_KEY=...
# AGENT_MODEL=google_genai:gemini-2.5-pro
# AGENT_FAST_MODEL=google_genai:gemini-2.5-flash

# --- Local: Ollama (recommended on Apple Silicon) ---
# 1. brew install ollama && brew services start ollama
# 2. Pick ONE big model that supports tool calling, then pair a small fast model.
#    The picker UI auto-discovers everything you've pulled.
#
#    Tested combos (May 2026):
#      ollama pull qwen2.5:14b      # ~9 GB · default · solid tool calling
#      ollama pull hermes3:8b       # ~5 GB · Nous Hermes 3 · explicitly tuned for tools
#      ollama pull qwen2.5:32b      # ~20 GB · best quality, needs M-series 36 GB+ RAM
#
#    DO NOT pick as big model (no tool calling on Ollama):
#      deepseek-r1:*, deepseek-coder-v2:*, gemma*, phi*, llama3.2:1b/3b
# 3. uncomment one combo below.
# AGENT_MODEL=ollama:qwen2.5:14b
# AGENT_FAST_MODEL=ollama:qwen2.5:7b
# AGENT_MODEL=ollama:hermes3:8b              # Nous Hermes 3 · fine-tuned for function calling
# AGENT_FAST_MODEL=ollama:qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434     # only set if non-default

# --- Local: LM Studio / vLLM / llama.cpp (any OpenAI-compatible server) ---
# AGENT_MODEL=openai:Qwen2.5-14B-Instruct
# AGENT_FAST_MODEL=openai:Qwen2.5-7B-Instruct
# OPENAI_BASE_URL=http://localhost:1234/v1   # LM Studio default; vLLM uses /v1 too
# OPENAI_API_KEY=local-no-key                # any non-empty string

# --- Web search backend (optional) ---
# Tavily gives much better signal than DuckDuckGo and is free for
# 1000 queries/month. Get a key at https://tavily.com — set it here
# and the web_search tool will prefer Tavily, falling back to DDG on
# error. Leave blank to use DuckDuckGo only (keyless, rate-limited).
TAVILY_API_KEY=

# --- Workspace, memory, trace files ---
AGENT_WORKDIR=./data/workspace
CHROMA_DIR=./data/chroma
TRACE_FILE=./data/traces.jsonl
CHECKPOINT_DB=./data/checkpoints.sqlite

# --- Cost & safety knobs ---
# Block any session that costs more than this in USD (0 = unlimited)
AGENT_SESSION_BUDGET_USD=0.50
# Tools time out after this many seconds, then return an error result
AGENT_TOOL_TIMEOUT_S=30
# Truncate any single tool result to this many chars before feeding back to the LLM
AGENT_TOOL_RESULT_MAX_CHARS=4000

# --- Memory hygiene ---
# Skip writing a fact / reflection if a near-duplicate already exists
# (cosine similarity above this threshold)
AGENT_DEDUP_THRESHOLD=0.92

# --- Tool routing (0 = bind all 11 tools every turn) ---
# Set to e.g. 5 to bind only the 5 most-relevant tools per user query
AGENT_TOOL_ROUTE_TOPK=0

# =====================================================================
# Security · all optional. Leave blank for local dev (no auth, no limit).
# =====================================================================

# Shared API key. Clients must send `X-API-Key: <value>` on mutating
# endpoints (POST /chat, POST /model, DELETE /memory, …).
# Leave unset to DISABLE auth (dev mode).
API_KEY=

# Rate limiting (per-IP, in-memory). Default ON when slowapi installed.
# Set RATE_LIMIT_ENABLED=0 to disable in tests.
RATE_LIMIT_ENABLED=1
RATE_LIMIT_CHAT=60/minute
RATE_LIMIT_READ=600/minute

# CORS · comma-separated origins. Default "*" for demo.
ALLOWED_ORIGINS=*

# Sentry · leave blank to disable. With a DSN, exceptions auto-report.
SENTRY_DSN=
SENTRY_ENV=dev
SENTRY_TRACES_SAMPLE_RATE=0.1

# =====================================================================
# Observability · OpenTelemetry + Prometheus
# =====================================================================

# OTLP collector endpoint.
# Leave blank → traces print to stdout (handy for local dev).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=taotao-agent
OTEL_DEPLOYMENT_ENVIRONMENT=dev   # dev | staging | prod (free-form)
OTEL_RESOURCE_ATTRIBUTES=service.namespace=taotao,deployment.environment=dev

# OTLP transport · default `grpc` (port :4317).  Switch to `http/protobuf`
# (port :4318) for any cloud SaaS that accepts standard HTTPS:
#   OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
#
# Send data through a hosted backend by setting endpoint + headers.
# Example · Honeycomb:
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io/v1/traces
#   OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
#   OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_INGEST_KEY
#
# Example · Grafana Cloud (Tempo):
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-2.grafana.net/otlp
#   OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(instance_id:api_key)>
#
# Example · Datadog Agent (forward to dd-agent OTLP receiver):
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://dd-agent:4318
#   OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
#
# Example · local Jaeger / Tempo:
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
#   OTEL_EXPORTER_OTLP_PROTOCOL=grpc
#
# Comma-separated key=value pairs · auth tokens, dataset names, etc.
OTEL_EXPORTER_OTLP_HEADERS=
# Override TLS (1 = plain, 0 = TLS).  Auto: gRPC localhost = plain, HTTPS = TLS.
OTEL_EXPORTER_OTLP_INSECURE=

# Prometheus /metrics endpoint is always on at /metrics.

# =====================================================================
# Per-user quota · daily / monthly enforcement
# =====================================================================
#
# Set caps + flip QUOTA_ENABLED=1 to gate every /chat call. Caps of 0
# (or unset) = unlimited. Counters reset on calendar boundary
# (UTC midnight for daily, UTC 1st for monthly).
#
# Storage: sqlite at <chroma_dir>/../quota.sqlite. Postgres swap is
# straightforward · rewrite agent/quota.py:_conn() to use psycopg.
# =====================================================================
# Postgres (optional) · production-grade LangGraph checkpointer
# =====================================================================
#
# When unset, the graph uses SqliteSaver (single-process, file-locked).
# When set, swaps to AsyncPostgresSaver · supports multiple uvicorn
# workers, durable across restarts, snapshot via pg_dump.
#
# Schema migration runs automatically on first connect (idempotent
# CREATE TABLE IF NOT EXISTS via langgraph-checkpoint-postgres).
#
# Local dev with docker compose:
#   DATABASE_URL=postgresql://taotao:taotao_dev_password@postgres:5432/taotao
DATABASE_URL=

# =====================================================================
# Per-user quota · daily / monthly enforcement (cont.)
# =====================================================================

QUOTA_ENABLED=0
QUOTA_DAILY_TOKENS=100000     # 100k tokens/day  (~$2 on Claude Sonnet 4.5)
QUOTA_MONTHLY_TOKENS=2000000  # 2M tokens/month  (~$40 on Claude Sonnet 4.5)
QUOTA_DAILY_USD=5.0           # OR · cap by spend instead
QUOTA_MONTHLY_USD=100.0
# Bootstrap admins · these user_ids get role=admin promoted at request time
ADMIN_USERS=

# =====================================================================
# Stripe metered billing (optional · skeleton)
# =====================================================================
#
# Set these to enable /billing/* endpoints.  Without them, /billing/me
# returns the tenant's local plan (always 'free' until upgraded) and
# /billing/checkout returns 503.
#
# Get keys from https://dashboard.stripe.com/test/apikeys
#   STRIPE_API_KEY=sk_test_...        # secret key (NEVER commit)
#   STRIPE_WEBHOOK_SECRET=whsec_...   # from `stripe listen` or webhook dashboard
#
# Local dev with the Stripe CLI:
#   1. brew install stripe/stripe-cli/stripe
#   2. stripe login
#   3. stripe listen --forward-to localhost:8000/billing/webhook
#      → prints `whsec_xxx` · paste into STRIPE_WEBHOOK_SECRET
#   4. Trigger test events: `stripe trigger checkout.session.completed`
#
# Wire your Stripe Price IDs into agent/billing/plans.py · the skeleton
# leaves them as None so /billing/checkout 500s with a helpful error
# until you fill them in.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# =====================================================================
# python_repl tool sandbox · pick the backend per security threat model
# =====================================================================
#
# subprocess (default) · trusted dev · NOT safe for prompt injection
# docker     · production SaaS · isolated container, --network=none
# gvisor     · paranoid · syscall interception via runsc (gVisor)
#
# `gvisor` requires installing runsc on the host first:
#   wget -O- https://gvisor.dev/archive.key | sudo apt-key add -
#   echo 'deb https://storage.googleapis.com/gvisor/releases release main' | sudo tee /etc/apt/sources.list.d/gvisor.list
#   sudo apt-get update && sudo apt-get install -y runsc
#   sudo runsc install   # registers as docker runtime
PYTHON_REPL_SANDBOX=subprocess
PYTHON_REPL_DOCKER_IMAGE=python:3.12-slim    # pre-pull for fast cold start
PYTHON_REPL_DOCKER_MEMORY=256m
PYTHON_REPL_DOCKER_PIDS=64

# =====================================================================
# Model Context Protocol · expose taotao-agent's tools, consume others
# =====================================================================

# SERVER side · /mcp HTTP endpoint is on by default. Set to 0 to skip.
# stdio transport for Claude Desktop is always available via
# `uv run python -m agent.mcp` (env var ignored there).
MCP_HTTP_ENABLED=1

# Whitelist of tool names exposed over MCP. Default: read-only safe set
# (calculator, current_time, web_search, read/list/grep, recall, profile,
# load_skill). Use `*` to expose everything (write_file, python_repl,
# remember, update_profile · ONLY in trusted environments).
# MCP_EXPOSED_TOOLS=calculator,current_time,web_search
# MCP_EXPOSED_TOOLS=*

# Optional bearer token clients must send via Authorization header.
# Leave blank for trusted localhost / Claude-Desktop-spawned subprocess.
# MCP_AUTH_TOKEN=

# CLIENT side · path to a Claude-Desktop-shaped JSON config of OTHER MCP
# servers we should pull tools from. Their tools land in our registry
# named `<server>__<tool>`. Leave blank to skip.
# Example file:  see backend/mcp_servers.example.json
# MCP_CLIENT_CONFIG=./mcp_servers.json
