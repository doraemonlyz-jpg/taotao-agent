# Pick ONE provider — fill the matching key.
# The default model used by the agent is controlled by AGENT_MODEL.

# --- Anthropic (default) ---
ANTHROPIC_API_KEY=sk-ant-...
AGENT_MODEL=anthropic:claude-sonnet-4-5-20250929
AGENT_FAST_MODEL=anthropic:claude-haiku-4-5

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# AGENT_MODEL=openai:gpt-4o
# AGENT_FAST_MODEL=openai:gpt-4o-mini

# --- Google Gemini ---
# GOOGLE_API_KEY=...
# AGENT_MODEL=google_genai:gemini-2.5-pro
# AGENT_FAST_MODEL=google_genai:gemini-2.5-flash

# --- Local: Ollama (recommended on Apple Silicon) ---
# 1. brew install ollama && brew services start ollama
# 2. ollama pull qwen2.5:14b           # big model — tool calling works well
# 3. ollama pull qwen2.5:7b            # fast/router model
# 4. uncomment below.
# AGENT_MODEL=ollama:qwen2.5:14b
# AGENT_FAST_MODEL=ollama:qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434     # only set if non-default

# --- Local: LM Studio / vLLM / llama.cpp (any OpenAI-compatible server) ---
# AGENT_MODEL=openai:Qwen2.5-14B-Instruct
# AGENT_FAST_MODEL=openai:Qwen2.5-7B-Instruct
# OPENAI_BASE_URL=http://localhost:1234/v1   # LM Studio default; vLLM uses /v1 too
# OPENAI_API_KEY=local-no-key                # any non-empty string

# --- Workspace, memory, trace files ---
AGENT_WORKDIR=./data/workspace
CHROMA_DIR=./data/chroma
TRACE_FILE=./data/traces.jsonl
CHECKPOINT_DB=./data/checkpoints.sqlite

# --- Cost & safety knobs ---
# Block any session that costs more than this in USD (0 = unlimited)
AGENT_SESSION_BUDGET_USD=0.50
# Tools time out after this many seconds, then return an error result
AGENT_TOOL_TIMEOUT_S=30
# Truncate any single tool result to this many chars before feeding back to the LLM
AGENT_TOOL_RESULT_MAX_CHARS=4000

# --- Memory hygiene ---
# Skip writing a fact / reflection if a near-duplicate already exists
# (cosine similarity above this threshold)
AGENT_DEDUP_THRESHOLD=0.92

# --- Tool routing (0 = bind all 11 tools every turn) ---
# Set to e.g. 5 to bind only the 5 most-relevant tools per user query
AGENT_TOOL_ROUTE_TOPK=0
