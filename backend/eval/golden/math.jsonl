{"id":"math.002","category":"math","user":"Compute 17! and tell me how many digits it has.","expected_substrings":["355687428096000","15"],"expected_tools":["calculator","python"],"rubric":"17! = 355687428096000 (15 digits)","weight":1.0,"tags":["arithmetic","factorial"]}
{"id":"math.003","category":"math","user":"What's the natural log of 1000? Round to 3 decimals.","expected_substrings":["6.908"],"expected_tools":["calculator","python"],"rubric":"ln(1000) ≈ 6.908","weight":1.0,"tags":["log"]}
{"id":"math.004","category":"math","user":"How many primes are there below 100?","expected_substrings":["25"],"expected_tools":["python"],"rubric":"There are 25 primes below 100","weight":1.0,"tags":["primes"]}
